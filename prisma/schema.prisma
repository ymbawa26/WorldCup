generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TournamentStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum PlayerPosition {
  GK
  DF
  MF
  FW
}

enum PreferredFoot {
  LEFT
  RIGHT
  BOTH
}

model DataSource {
  id                String                  @id
  name              String
  url               String
  retrievedAt       DateTime
  publishedAt       String?
  sha256            String?
  licenseNote       String
  tournamentSources TournamentSource[]
  playerSources     PlayerDataSource[]
  squadPlayers      TournamentSquadPlayer[]
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model Tournament {
  id              String             @id @default(uuid()) @db.Uuid
  slug            String             @unique
  name            String
  dataVersion     String             @unique
  startsAt        DateTime
  resultsIncluded Boolean            @default(false)
  teams           TournamentTeam[]
  groups          TournamentGroup[]
  fixtures        Fixture[]
  sources         TournamentSource[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model TournamentSource {
  tournamentId String     @db.Uuid
  sourceId     String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  source       DataSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@id([tournamentId, sourceId])
}

model Team {
  id               String           @id @default(uuid()) @db.Uuid
  slug             String           @unique
  name             String
  shortName        String
  fifaCode         String           @unique @db.Char(3)
  flagCode         String
  confederation    String
  sourceExternalId String?          @unique
  tournamentTeams  TournamentTeam[]
  players          Player[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model TournamentTeam {
  id               String                  @id @default(uuid()) @db.Uuid
  tournamentId     String                  @db.Uuid
  teamId           String                  @db.Uuid
  fifaRank         Int
  previousFifaRank Int
  fifaPoints       Decimal                 @db.Decimal(10, 6)
  tournament       Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team             Team                    @relation(fields: [teamId], references: [id], onDelete: Restrict)
  memberships      GroupMembership[]
  homeFixtures     Fixture[]               @relation("HomeTournamentTeam")
  awayFixtures     Fixture[]               @relation("AwayTournamentTeam")
  squadPlayers     TournamentSquadPlayer[]

  @@unique([tournamentId, teamId])
}

model TournamentGroup {
  id           String            @id @default(uuid()) @db.Uuid
  tournamentId String            @db.Uuid
  code         String            @db.Char(1)
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  memberships  GroupMembership[]
  fixtures     Fixture[]

  @@unique([tournamentId, code])
}

model GroupMembership {
  id               String          @id @default(uuid()) @db.Uuid
  groupId          String          @db.Uuid
  tournamentTeamId String          @db.Uuid
  drawPosition     Int
  group            TournamentGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tournamentTeam   TournamentTeam  @relation(fields: [tournamentTeamId], references: [id], onDelete: Cascade)

  @@unique([groupId, drawPosition])
  @@unique([groupId, tournamentTeamId])
}

model Stadium {
  id        String    @id @default(uuid()) @db.Uuid
  slug      String    @unique
  name      String
  city      String
  country   String
  fixtures  Fixture[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Player {
  id               String                  @id @db.Uuid
  externalIdentity String                  @unique
  nationalTeamId   String                  @db.Uuid
  fullName         String
  displayName      String
  firstNames       String
  lastNames        String
  shirtName        String
  dateOfBirth      DateTime                @db.Date
  heightCm         Int
  primaryPosition  PlayerPosition
  preferredFoot    PreferredFoot?
  nationalTeam     Team                    @relation(fields: [nationalTeamId], references: [id], onDelete: Restrict)
  clubs            PlayerClub[]
  tournamentSquads TournamentSquadPlayer[]
  sources          PlayerDataSource[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([nationalTeamId])
  @@index([fullName])
}

model Club {
  id          String       @id @db.Uuid
  name        String
  countryCode String       @db.Char(3)
  players     PlayerClub[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, countryCode])
}

model PlayerClub {
  id          String  @id @db.Uuid
  playerId    String  @db.Uuid
  clubId      String  @db.Uuid
  dataVersion String
  isCurrent   Boolean @default(true)
  player      Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club        Club    @relation(fields: [clubId], references: [id], onDelete: Restrict)

  @@unique([playerId, dataVersion])
  @@index([clubId])
}

model TournamentSquadPlayer {
  id                 String         @id @db.Uuid
  tournamentTeamId   String         @db.Uuid
  playerId           String         @db.Uuid
  sourceId           String
  squadNumber        Int
  registeredPosition PlayerPosition
  internationalCaps  Int
  internationalGoals Int
  tournamentTeam     TournamentTeam @relation(fields: [tournamentTeamId], references: [id], onDelete: Cascade)
  player             Player         @relation(fields: [playerId], references: [id], onDelete: Restrict)
  source             DataSource     @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@unique([tournamentTeamId, playerId])
  @@unique([tournamentTeamId, squadNumber])
  @@index([playerId])
  @@index([sourceId])
}

model PlayerDataSource {
  playerId        String     @db.Uuid
  sourceId        String
  fields          Json
  confidenceScore Decimal    @db.Decimal(4, 3)
  isEstimated     Boolean    @default(false)
  player          Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  source          DataSource @relation(fields: [sourceId], references: [id], onDelete: Restrict)

  @@id([playerId, sourceId])
  @@index([sourceId])
}

model Fixture {
  id                   String           @id @default(uuid()) @db.Uuid
  tournamentId         String           @db.Uuid
  matchNumber          Int
  stage                TournamentStage
  scheduledDate        DateTime
  simultaneousKey      String?
  groupId              String?          @db.Uuid
  stadiumId            String           @db.Uuid
  homeTournamentTeamId String?          @db.Uuid
  awayTournamentTeamId String?          @db.Uuid
  homeSlot             String?
  awaySlot             String?
  tournament           Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  group                TournamentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  stadium              Stadium          @relation(fields: [stadiumId], references: [id], onDelete: Restrict)
  homeTournamentTeam   TournamentTeam?  @relation("HomeTournamentTeam", fields: [homeTournamentTeamId], references: [id], onDelete: Restrict)
  awayTournamentTeam   TournamentTeam?  @relation("AwayTournamentTeam", fields: [awayTournamentTeamId], references: [id], onDelete: Restrict)

  @@unique([tournamentId, matchNumber])
  @@index([groupId])
  @@index([stadiumId])
}
