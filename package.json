{
  "name": "world-cup-simulation",
  "version": "0.1.0",
  "private": true,
  "description": "A data-driven 2026 international football tournament management simulation.",
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:property": "vitest run tests/property",
    "test:e2e": "playwright test",
    "validate:data": "node --import tsx scripts/validate-data.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:seed": "node --import tsx prisma/seed.ts",
    "db:smoke": "node --import tsx scripts/data/verify-postgres-seed.ts",
    "data:fetch:squads": "node --import tsx scripts/data/fetch-official-squads.ts",
    "data:extract:squads": "node --import tsx scripts/data/extract-official-squads.ts",
    "data:normalize": "node --import tsx scripts/data/normalize-player-data.ts",
    "data:validate": "node --import tsx scripts/data/validate-dataset.ts",
    "data:export": "node --import tsx scripts/data/export-dataset.ts",
    "data:pipeline:cached": "npm run data:extract:squads && npm run data:normalize && npm run data:validate && npm run data:export",
    "data:pipeline": "npm run data:fetch:squads && npm run data:pipeline:cached",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test:unit && npm run test:integration && npm run test:property && npm run validate:data && npm run db:validate && npm run build"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@electric-sql/pglite-socket": "^0.2.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
